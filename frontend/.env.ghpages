# GitHub Pages deployment — no backend, demo/static mode only.
# Vite inlines all VITE_* vars at build time, so leave these empty
# to prevent leaking private IPs or secrets into the public JS bundle.

# Empty = app falls back to window.location.hostname defaults,
# which will fail gracefully on GitHub Pages (no backend available).
VITE_BFF_URL=
VITE_CHART_BFF_URL=
VITE_TICKDATA_URL=

VITE_IBBOT_URL=
VITE_PRIVACY_PIN=1234
